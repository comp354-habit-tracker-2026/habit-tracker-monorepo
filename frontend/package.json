{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "build": "tsc -b && vite build --mode prod",
    "build:prod": "tsc -b && vite build --mode prod",
    "build:dev": "tsc -b && vite build --mode dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "preview": "vite preview --mode prod",
    "preview:dev": "vite preview --mode dev",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:headed": "cypress run --headed",
    "cypress:ci": "start-server-and-test 'npm run dev' http://localhost:5173 cypress:run"
  },
  "dependencies": {
    "@coreui/coreui": "^5.6.1",
    "@coreui/coreui-pro": "^5.24.2",
    "@coreui/react": "^5.10.0",
    "@coreui/react-pro": "^5.24.1",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.1.1",
    "react-router": "^7.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "cypress": "^14.5.4",
    "eslint": "^9.39.1",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "start-server-and-test": "^2.1.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
